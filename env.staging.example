# Staging Webflow site — copy to .env.local for local testing:
#   cp env.staging.example .env.local
#
# Fetches https://maintainx-tonik.webflow.io/sitemap.xml and rewrites loc URLs to SITEMAP_PUBLIC_ORIGIN.

ORIGIN_DOMAIN=https://maintainx-tonik.webflow.io
# Staging sitemap <loc> values use the published Webflow domain, not *.webflow.io
SITEMAP_LOC_REPLACE_PREFIXES=https://webflow.getmaintainx.com
SITEMAP_PUBLIC_ORIGIN=https://www.getmaintainx.com
SITEMAP_LIMIT=45000
BASE_PATH=root
