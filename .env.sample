ORIGIN_DOMAIN=https://webflow.getmaintainx.com
# Canonical origin for <loc> after rewrite (omit to default to https://www.getmaintainx.com; set to empty to disable rewriting)
SITEMAP_PUBLIC_ORIGIN=https://www.getmaintainx.com
SITEMAP_LIMIT=45000

# Set to "root" for sitemap at /sitemap.xml (no path prefix)
# Omit or use a path like "/config" for a prefixed path
BASE_PATH=root

# Staging Webflow (local testing): copy env.staging.example to .env.local
# ORIGIN_DOMAIN=https://maintainx-tonik.webflow.io
# SITEMAP_LOC_REPLACE_PREFIXES=https://webflow.getmaintainx.com